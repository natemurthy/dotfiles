gw() {
  # Check if branch name argument is provided
  if [[ -z "$1" ]]; then
    echo "Error: Branch name required" >&2
    echo "Usage: gw <branch-name>" >&2
    return 1
  fi

  # Check if we're inside a git repository
  if [[ ! -d .git ]] && ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: Not in a git repository" >&2
    return 1
  fi

  # Get the main worktree path (the original repo)
  local main_worktree=$(git worktree list | head -n 1 | awk '{print $1}')
  local repo_name=$(basename "$main_worktree")
  
  local branch_name="$1"
  # Replace slashes with hyphens for the directory name
  local dir_name="${branch_name//\//-}"
  local worktree_path="$(dirname "$main_worktree")/${repo_name}-${dir_name}"

  # Create the worktree
  if git worktree add -b "$branch_name" "$worktree_path"; then
    # Change to the new worktree directory
    cd "$worktree_path" || return 1
    echo "✓ Switched to worktree: $(pwd)"
  else
    echo "Error: Failed to create worktree" >&2
    return 1
  fi
}
